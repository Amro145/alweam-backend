{
  "name": "my-app",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply weamdb --local",
    "db:migrate:remote": "wrangler d1 migrations apply weamdb --remote",
    "db:seed": "tsx src/db/seed.ts",
    "db:seed:dev": "for f in .wrangler/state/v3/d1/miniflare-D1DatabaseObject/*.sqlite; do [ \"$(basename $f)\" != \"metadata.sqlite\" ] && tsx src/db/seed.ts \"$f\"; done",
    "db:seed:remote": "wrangler d1 execute weamdb --remote --file=seed.sql"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "@libsql/client": "^0.17.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.12",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260410.1",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.3",
    "wrangler": "^4.4.0"
  }
}
